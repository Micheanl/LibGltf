#version 460
#extension GL_EXT_mesh_shader : require
layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 64, max_primitives = 124) out;
layout(set = 0, binding = PROJECTION_BINDING, std140) uniform Projection { mat4 ProjMat; };
layout(set = 0, binding = DYNAMIC_TRANSFORMS_BINDING, std140) uniform DynamicTransforms { mat4 ModelViewMat; vec4 ColorModulator; vec3 ModelOffset; mat4 TextureMat; };
layout(set = 0, binding = LIGHTING_BINDING, std140) uniform Lighting { vec3 Light0_Direction; vec3 Light1_Direction; };
layout(set = 0, binding = SAMPLER1_BINDING) uniform sampler2D Sampler1;
layout(set = 0, binding = SAMPLER2_BINDING) uniform sampler2D Sampler2;
layout(set = 0, binding = GEOMETRY_BINDING, std430) readonly buffer Geometry { uint geometryWords[]; };
layout(set = 0, binding = INSTANCES_BINDING, std430) readonly buffer Instances { uint instanceWords[]; };
struct Meshlet { vec4 sphere; uint vertexOffset; uint triangleOffset; uint vertexCount; uint triangleCount; uint firstIndex; uint indexCount; uint padding0; uint padding1; };
layout(set = 0, binding = MESHLETS_BINDING, std430) readonly buffer Meshlets { Meshlet meshlets[]; };
layout(set = 0, binding = MESHLET_VERTICES_BINDING, std430) readonly buffer MeshletVertices { uint meshletVertices[]; };
layout(set = 0, binding = MESHLET_TRIANGLES_BINDING, std430) readonly buffer MeshletTriangles { uint meshletTriangleWords[]; };
struct TaskPayload { uint instanceIndices[32]; uint meshletIndices[32]; };
taskPayloadSharedEXT TaskPayload payload;
layout(location = 0) out float sphericalVertexDistance[];
layout(location = 1) out float cylindricalVertexDistance[];
layout(location = 2) out vec4 vertexColor[];
layout(location = 3) out vec4 lightMapColor[];
layout(location = 4) out vec4 overlayColor[];
layout(location = 5) out vec2 texCoord0[];
mat4 instanceMatrix(uint o) {
    return mat4(uintBitsToFloat(instanceWords[o]), uintBitsToFloat(instanceWords[o + 1]), uintBitsToFloat(instanceWords[o + 2]), uintBitsToFloat(instanceWords[o + 3]), uintBitsToFloat(instanceWords[o + 4]), uintBitsToFloat(instanceWords[o + 5]), uintBitsToFloat(instanceWords[o + 6]), uintBitsToFloat(instanceWords[o + 7]), uintBitsToFloat(instanceWords[o + 8]), uintBitsToFloat(instanceWords[o + 9]), uintBitsToFloat(instanceWords[o + 10]), uintBitsToFloat(instanceWords[o + 11]), uintBitsToFloat(instanceWords[o + 12]), uintBitsToFloat(instanceWords[o + 13]), uintBitsToFloat(instanceWords[o + 14]), uintBitsToFloat(instanceWords[o + 15]));
}
int signed16(uint value) { return int(value << 16) >> 16; }
uint triangleByte(uint offset) { return meshletTriangleWords[offset >> 2] >> ((offset & 3) * 8) & 255; }
vec4 mixLight(vec3 normal, vec4 color) {
    vec2 light = max(vec2(0.0), vec2(dot(Light0_Direction, normal), dot(Light1_Direction, normal)));
    float value = min(1.0, (light.x + light.y) * 0.6 + 0.4);
    return vec4(color.rgb * value, color.a);
}
vec4 sampleLightmap(ivec2 uv) {
    vec2 coord = clamp((vec2(uv) / 256.0) + 0.5 / 16.0, vec2(0.5 / 16.0), vec2(15.5 / 16.0));
    return texture(Sampler2, coord);
}
void main() {
    uint payloadIndex = gl_WorkGroupID.x;
    uint instanceIndex = payload.instanceIndices[payloadIndex];
    Meshlet meshlet = meshlets[payload.meshletIndices[payloadIndex]];
    SetMeshOutputsEXT(meshlet.vertexCount, meshlet.triangleCount);
    uint invocation = gl_LocalInvocationIndex;
    uint io = instanceIndex * 35;
    if (invocation < meshlet.vertexCount) {
        uint vertexIndex = meshletVertices[meshlet.vertexOffset + invocation];
        uint vo = vertexIndex * 15;
        vec3 position = vec3(uintBitsToFloat(geometryWords[vo]), uintBitsToFloat(geometryWords[vo + 1]), uintBitsToFloat(geometryWords[vo + 2]));
        vec3 normal = vec3(uintBitsToFloat(geometryWords[vo + 3]), uintBitsToFloat(geometryWords[vo + 4]), uintBitsToFloat(geometryWords[vo + 5]));
        vec2 uv = vec2(uintBitsToFloat(geometryWords[vo + 10]), uintBitsToFloat(geometryWords[vo + 11]));
        vec4 color = unpackUnorm4x8(geometryWords[vo + 14]);
        mat4 transform = instanceMatrix(io);
        mat3 normalTransform = mat3(uintBitsToFloat(instanceWords[io + 16]), uintBitsToFloat(instanceWords[io + 17]), uintBitsToFloat(instanceWords[io + 18]), uintBitsToFloat(instanceWords[io + 20]), uintBitsToFloat(instanceWords[io + 21]), uintBitsToFloat(instanceWords[io + 22]), uintBitsToFloat(instanceWords[io + 24]), uintBitsToFloat(instanceWords[io + 25]), uintBitsToFloat(instanceWords[io + 26]));
        vec4 instanceColor = vec4(uintBitsToFloat(instanceWords[io + 28]), uintBitsToFloat(instanceWords[io + 29]), uintBitsToFloat(instanceWords[io + 30]), uintBitsToFloat(instanceWords[io + 31]));
        uint light = instanceWords[io + 32];
        uint overlay = instanceWords[io + 33];
        vec4 worldPosition = transform * vec4(position, 1.0);
        vec3 worldNormal = normalize(normalTransform * normal);
        gl_MeshVerticesEXT[invocation].gl_Position = ProjMat * ModelViewMat * worldPosition;
        sphericalVertexDistance[invocation] = length(worldPosition.xyz);
        cylindricalVertexDistance[invocation] = max(length(worldPosition.xz), abs(worldPosition.y));
        vertexColor[invocation] = mixLight(worldNormal, color * instanceColor);
        lightMapColor[invocation] = sampleLightmap(ivec2(signed16(light), signed16(light >> 16)));
        overlayColor[invocation] = texelFetch(Sampler1, ivec2(signed16(overlay), signed16(overlay >> 16)), 0);
        texCoord0[invocation] = uv;
    }
    for (uint triangle = invocation; triangle < meshlet.triangleCount; triangle += gl_WorkGroupSize.x) {
        uint offset = meshlet.triangleOffset + triangle * 3;
        gl_PrimitiveTriangleIndicesEXT[triangle] = uvec3(triangleByte(offset), triangleByte(offset + 1), triangleByte(offset + 2));
    }
}